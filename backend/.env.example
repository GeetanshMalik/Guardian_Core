# Port for the Express server to listen on
PORT=3000

# Node Environment (production, development)
NODE_ENV=production

# The URL where the frontend is hosted
FRONTEND_URL=https://frontend-service-url-here.a.run.app

# The URL where this backend is hosted
APP_URL=https://backend-service-url-here.a.run.app

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=https://frontend-service-url-here.a.run.app

# Admin emails (comma-separated)
ADMIN_EMAILS=geetansh@example.com

# Google Cloud Platform configuration
GOOGLE_CLOUD_PROJECT_ID=deadline-guardian-ai-500420
FIRESTORE_DATABASE_ID=deadline-guardian-ai

# Google OAuth Client Credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://backend-service-url-here.a.run.app/auth/google/callback

# Gemini API Configuration
GEMINI_API_KEY=your-gemini-api-key

# JWT & Encryption secrets (e.g. 32+ characters / 32 hex bytes)
JWT_SECRET=your-secure-jwt-secret-key-at-least-32-chars
ENCRYPTION_KEY=your-secure-encryption-key-32-bytes-in-hex
